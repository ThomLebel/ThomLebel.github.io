---
import '../styles/global.css'
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Thomas Lebel — Intégrateur HTML5 · Bannières · Emailing</title>
		<meta name="description" content="Portfolio de Thomas Lebel, intégrateur HTML5 spécialisé bannières GSAP, emailing MJML et intégration CMS. Clients : Air France, Orange, ENGIE, Renault, Peugeot.">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
		<script src="https://use.fontawesome.com/b20abecad8.js"></script>
		<style is:global>
			:root {
				--bg: #0A0F1A;
				--text: #F0F4FF;
				--accent-green: #00F5A0;
				--accent-blue: #0080FF;
				--accent-cyan: #00C8FF;
				--surface: rgba(255,255,255,0.04);
				--border: rgba(255,255,255,0.08);
			}

			*{
				box-sizing: border-box;
    			user-select: none;
			}

			html, body {
				margin: 0;
				width: 100%;
				height: 100%;
				background: var(--bg);
				color: var(--text);
				font-family: 'Inter', sans-serif;
				font-size: 16px;
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
